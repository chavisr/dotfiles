#! /bin/sh

pgrep -x sxhkd > /dev/null || sxhkd &
#pgrep -x lxsession > /dev/null || lxsession -n -a &
pgrep -x picom > /dev/null || picom --backend xrender &

feh --no-fehbg --bg-fill '/home/chavi/.config/wallpaper/mountain.jpg' &
$HOME/.config/polybar/launch.sh &

bspc monitor -d I II III IV V VI VII

bspc config border_width	2
bspc config window_gap		6
bspc config normal_border_color "#2e2e2e"
bspc config focused_border_color "#808184"
bspc config swallow_first_click  false

bspc config split_ratio          0.52
bspc config borderless_monocle   true
bspc config gapless_monocle      true
