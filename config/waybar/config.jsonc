{


    //--------------------------------------------------------------------------------
    //    General
    //--------------------------------------------------------------------------------

    "layer": "top", 
    "position": "top",
    "height": 36,
    "spacing": 0,
    "margin-top": 7,
    "margin-left": 50,
    "margin-bottom": 1,
    "margin-right": 50,



    //--------------------------------------------------------------------------------
    //    Left Modules
    //--------------------------------------------------------------------------------

    "modules-left": [
	    "clock",
        "river/tags",
	    "river/mode"
    ],



    //--------------------------------------------------------------------------------
    //    Center Modules
    //--------------------------------------------------------------------------------

    "modules-center": [
    ],



    //--------------------------------------------------------------------------------
    //    Right Modules
    //--------------------------------------------------------------------------------

    "modules-right": [
        "tray",        
        "bluetooth",
        "network",
        "cpu",
        "memory"
    ],
     
    

    //--------------------------------------------------------------------------------
    //    Left Configuration
    //--------------------------------------------------------------------------------
     

    "clock": {
        "format": "{:%d-%m-%Y  | %I:%M}",
	    "tooltip-format": "{:%A}"
    },

    "river/tags": {
        "num-tags": 3
    },


    //--------------------------------------------------------------------------------
    //    Right Configuration
    //--------------------------------------------------------------------------------

    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },

    "bluetooth": {
	    "format": "󰂲",
        "format-on": "",
	    "format-connected": " {num_connections}",
	    "tooltip-format": "{status}",
	    "tooltip-format-connected": "{device_alias}",
	    "on-click": "kitty --class bluetui -e bluetui",
	    "interval": 1
    },
        
    "memory": {
        "interval": 1,
        "format": "{}% "
    },
        
    "cpu": {
        "format": "{usage}% ",
        "interval": 1
    },

    "battery": {
        "states": {
            "good": 90,
            "warning": 15,
            "critical": 5
        },
        "format": "{capacity}  {icon}",
        "format-full": "{capacity} {icon}",
        "format-charging": "{capacity}  ",
        "format-plugged": "{capacity}  ",
        "format-icons": ["", "", "", "", ""]
    },

    "network": {
        "format-wifi": "",
        "format-disconnected": "⚠",
	    "tooltip-format": "{essid}"
    }
}
